+std::optional<std::string> trustedSystemProgramPath(const std::string& name) {
+    const char* pathEnv = std::getenv("PATH");
+    if (!pathEnv || !*pathEnv)
+        return std::nullopt;
+    std::string_view path(pathEnv);
+    while (!path.empty()) {
+        auto sep = path.find(':');
+        auto dir = std::string(sep == std::string_view::npos ? path : path.substr(0, sep));
